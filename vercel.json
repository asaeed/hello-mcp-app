{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "dist/**"
    }
  },
  "rewrites": [
    { "source": "/mcp",        "destination": "/api/index" },
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/app",        "destination": "/api/index" }
  ]
}
